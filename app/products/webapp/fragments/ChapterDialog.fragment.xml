<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Dialog
        id="addChapterDialog"
        title="{i18n>addChapterTitle}"
        contentWidth="400px"
        draggable="true"
        resizable="true">

        <content>
            <f:SimpleForm
                id="chapterForm"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                labelSpanS="12"
                columnsXL="1"
                columnsL="1"
                columnsM="1">

                <f:content>
                    <Label id="chapterNameLabel" text="{i18n>chapterNameLabel}" required="true"/>
                    <Input
                        id="chapterNameInput"
                        placeholder="{i18n>chapterNamePlaceholder}"
                        value="{newChapter>/chapterName}"
                        maxLength="100"
                        valueLiveUpdate="true"
                        liveChange=".onChapterNameLiveChange"/>
                </f:content>

            </f:SimpleForm>
        </content>

        <buttons>
            <Button
                id="saveChapterBtn"
                text="{i18n>save}"
                type="Emphasized"
                enabled="{newChapter>/isValid}"
                press=".onSaveChapter"/>
            <Button
                id="cancelChapterBtn"
                text="{i18n>cancel}"
                press=".onCancelChapter"/>
        </buttons>

    </Dialog>

</core:FragmentDefinition>